{
  "name": "ado-sync",
  "version": "0.1.55",
  "description": "Bidirectional sync between local test specs (Cucumber/Markdown) and Azure DevOps Test Cases",
  "bin": {
    "ado-sync": "./dist/cli.js",
    "ado-sync-mcp": "./dist/mcp-server.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "dev": "ts-node src/cli.ts",
    "lint": "eslint src --ext .ts --quiet",
    "lint:fix": "eslint src --ext .ts --fix --quiet",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "azure-devops",
    "test-sync",
    "cucumber",
    "gherkin",
    "playwright",
    "specsync"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PavanMudigonda/ado-sync"
  },
  "license": "MIT",
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/messages": "^32.2.0",
    "@cucumber/tag-expressions": "^9.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "azure-devops-node-api": "^15.1.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.6",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "node-llama-cpp": "^3.18.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
