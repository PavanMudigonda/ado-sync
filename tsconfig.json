{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ESNext", "DOM"],
    "declaration": true,
    "declarationDir": "./dist",
    "sourceMap": true,
    "outDir": "./dist/",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "node_modules/openai/node_modules",
    "node_modules/@anthropic-ai/sdk/node_modules",
    "node_modules/@aws-sdk/client-bedrock-runtime/node_modules",
    "node_modules/ollama/node_modules",
    "node_modules/@azure-rest/ai-inference/node_modules",
    "node_modules/@azure/core-auth/node_modules"
  ]
}
